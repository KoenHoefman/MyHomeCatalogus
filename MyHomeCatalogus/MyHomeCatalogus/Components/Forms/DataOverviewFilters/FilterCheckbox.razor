<div class="form-check form-check-inline mb-0 d-flex align-items-center h-100">
    <input class="form-check-input"
           type="checkbox"
           id="@_id"
           checked="@Value"
           @onchange="OnInternalChange">
    <label class="form-check-label ms-2" for="@_id">
        @Label
    </label>
</div>

@code {
    private readonly string _id = $"chk_{Guid.NewGuid():N}";

    [Parameter] 
    public bool Value { get; set; }
    
    [Parameter] 
    public EventCallback<bool> ValueChanged { get; set; }
    
    [Parameter] 
    public string Label { get; set; } = "Filter";

    private async Task OnInternalChange(ChangeEventArgs e)
    {
        bool isChecked = (bool)(e.Value ?? false);
        await ValueChanged.InvokeAsync(isChecked);
    }
}