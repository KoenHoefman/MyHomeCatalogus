@using MyHomeCatalogus.Components.Extensions

@if (Model.Id != 0)
{
    <input type="hidden" name="Model.Id" value="@Model.Id" />
}

<AddUpdateFormRow>
    <LabelContent>
        <label for="name" class="form-label">Name (*):</label>
    </LabelContent>
    <InputContent>
        <InputText id="name" @bind-Value="Model.Name" class="form-control" aria-required="true" />
        <ValidationMessage For="() => Model.Name" class="text-danger" />
    </InputContent>
</AddUpdateFormRow>

<AddUpdateFormRow>
    <LabelContent>
        <label for="description" class="form-label">Description:</label>
    </LabelContent>
    <InputContent>
        <TextAreaWithCounter Id="description" @bind-Value="Model.Description" For="() => Model.Description" />
    </InputContent>
</AddUpdateFormRow>

<AddUpdateFormRow>
    <LabelContent>
        <label for="storageunitid" class="form-label">Storage unit (*):</label>
    </LabelContent>
    <InputContent>
        <InputSelect id="storageunitid" @bind-Value="Model.StorageUnitId" class="form-select" aria-required="true">

            <option value="0">-- Select a storage unit --</option>
            @foreach (var storageUnit in StorageUnits)
            {
                <option value="@storageUnit.Id">@storageUnit.ToDisplayString()</option>
            }
        </InputSelect>
        <ValidationMessage For="() => Model.StorageUnitId" class="text-danger" />
    </InputContent>
</AddUpdateFormRow>

@code {
    [Parameter, EditorRequired]
    public required Shelf Model { get; set; }

    [Parameter, EditorRequired]
    public required IEnumerable<StorageUnit> StorageUnits { get; set; }
}