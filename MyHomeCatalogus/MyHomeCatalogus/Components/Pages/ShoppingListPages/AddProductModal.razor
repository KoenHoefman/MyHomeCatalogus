@if (_isVisible)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Add product to list</h5>
                    <button type="button" class="btn-close" @onclick="CloseModal"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger d-flex align-items-center" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>
                            <div>
                                @_errorMessage
                            </div>
                        </div>
                    }

                    <div class="mb-3">

                        <select class="form-select @(!string.IsNullOrEmpty(_errorMessage) ? "is-invalid" : "")"
                                @bind="_selectedProductId">
                            <option value="0" disabled selected>-- Select a product --</option>
                            @if (_products!.Any())
                            {
                                @foreach (var product in _products!)
                                {
                                    <option value="@product.Id">@product.Name</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Quantity:</label>
                        <input type="number" class="form-control @(!string.IsNullOrEmpty(_errorMessage) ? "is-invalid" : "")"
                               @bind="_quantity" min="1"/>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="CloseModal">Cancel</button>
                    <button type="button" class="btn btn-primary" @onclick="AddProduct">Add to List</button>
                </div>
            </div>
        </div>
    </div>
}

