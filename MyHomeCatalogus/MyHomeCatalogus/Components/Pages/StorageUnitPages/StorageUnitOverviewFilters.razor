@using MyHomeCatalogus.Interfaces
@using MyHomeCatalogus.Components.Forms.DataOverviewFilters
@implements IFilterProvider<StorageUnit>

<FilterDelayedInput Value="@_nameFilter"
                    ValueChanged="HandleNameChanged"
                    Placeholder="Filter by name..." />


<FilterMultiSelect TItem="Room"
                   Label="Room"
                   Items="Rooms"
                   SelectedValues="_selectedRoomIds"
                   SelectedValuesChanged="HandleRoomIdChanged"
                   GetId="@(p => p.Id)"
                   GetName="@(p => p.Name)" />


@code {
    private string _nameFilter = string.Empty;
    private List<int> _selectedRoomIds = new();

    public bool IsActive => !string.IsNullOrWhiteSpace(_nameFilter) || _selectedRoomIds.Any();

    [CascadingParameter]
    public DataOverviewForm<StorageUnit>? ParentForm { get; set; }

    [Parameter, EditorRequired]
    public required IEnumerable<Room> Rooms { get; set; }



    protected override void OnInitialized()
    {
        ParentForm?.RegisterFilter(this);
    }

    public bool Matches(StorageUnit item)
    {
        var matchName = string.IsNullOrWhiteSpace(_nameFilter) ||
                        item.Name.Contains(_nameFilter, StringComparison.OrdinalIgnoreCase);

        var matchProductType = !_selectedRoomIds.Any() || _selectedRoomIds.Contains(item.RoomId);

        return matchName && matchProductType;
    }

    private async Task HandleNameChanged(string? value)
    {
        _nameFilter = value ?? string.Empty;
        await NotifyChanged();
    }


    private async Task HandleRoomIdChanged(List<int> values)
    {
        _selectedRoomIds = values;
        await NotifyChanged();
    }

    private async Task NotifyChanged()
    {
        if (ParentForm != null)
        {
            await ParentForm.RefreshAsync();
        }
    }

    public void Reset()
    {
        _nameFilter = string.Empty;
        _selectedRoomIds.Clear();

        StateHasChanged();
    }

}