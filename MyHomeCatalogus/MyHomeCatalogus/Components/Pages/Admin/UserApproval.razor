@page "/admin/approvals"

@attribute [Authorize(Policy = "ApprovedOnly")]

<h3>User Management</h3>

<table class="table table-hover mt-4">
	<thead class="table-dark">
	<tr>
		<th>Email</th>
		<th>Status</th>
		<th>Action</th>
	</tr>
	</thead>
	<tbody>
	@foreach (var user in users)
	{
		<tr>
			<td>@user.Email</td>
			<td>
				<span class="badge @(user.IsApproved ? "bg-success" : "bg-secondary")">
					@(user.IsApproved ? "Approved" : "Pending")
				</span>
			</td>
			<td>
				<button class="btn btn-sm @(user.IsApproved ? "btn-outline-danger" : "btn-success")" 
				        @onclick="() => ToggleApproval(user)">
					@(user.IsApproved ? "Revoke Access" : "Approve User")
				</button>
			</td>
		</tr>
	}
	</tbody>
</table>

@code {
}
