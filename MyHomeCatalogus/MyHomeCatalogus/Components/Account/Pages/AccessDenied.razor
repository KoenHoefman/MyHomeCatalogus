@page "/Account/AccessDenied"

@attribute [AllowAnonymous]

<PageTitle>Access denied</PageTitle>

<div class="container mt-5">
	<div class="card border-warning shadow">
		<div class="card-header bg-warning text-dark">
			<h1 class="h4 mb-0">Account Pending Approval</h1>
		</div>
		<div class="card-body text-center">
			<p class="lead">Thank you for registering!</p>
			<p>Your account has been created successfully, but an administrator needs to "green-light" your access.</p>
			<hr />
			<p class="text-muted small">Please contact the site owner to expedite this process.</p>
			<a href="/" class="btn btn-outline-primary">Return Home</a>
		</div>
	</div>
</div>
